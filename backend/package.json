{
    "name": "azure-pricing-backend",
    "version": "1.0.0",
    "description": "Backend for Azure Pricing Calculator — caches Azure pricing data in TursoDB",
    "main": "src/index.js",
    "type": "module",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "start": "node src/index.js",
        "dev": "node --watch --watch-path=./src src/index.js",
        "sync": "node -e \"import('./src/sync.js').then(m => m.runFullSync())\"",
        "sync:service": "node -e \"import('./src/sync.js').then(m => m.syncService(process.argv[1]))\" --"
    },  
    "dependencies": {
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "firebase": "^12.10.0",
        "firebase-admin": "^13.7.0",
        "google-auth-library": "^10.5.0",
        "jsonwebtoken": "^9.0.3",
        "node-cron": "^3.0.3",
        "node-fetch": "^3.3.2",
        "nodemailer": "^8.0.1",
        "pg": "^8.18.0",
        "razorpay": "^2.9.6",
        "stripe": "^20.4.1"
    }
}
